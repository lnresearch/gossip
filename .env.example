# LNR Gossip Pipeline Configuration Example

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
UPSTREAM_RABBITMQ_URL=amqp://guest:guest@upstream-server:5672/
UPSTREAM_QUEUE_NAME=gossip.raw

# Database Configuration  
DATABASE_PATH=gossip.db

# Archive Configuration
ARCHIVE_DIRECTORY=annex/dailies
ARCHIVE_ROTATION=daily

# Web Server Configuration
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Logging Configuration
LOG_LEVEL=INFO